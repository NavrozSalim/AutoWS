# Copy this file to .env (next to docker-compose.yml) and fill in real values.
# docker compose automatically reads a file named .env in this directory.

# ── Database ──
POSTGRES_DB=leeso
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# ── Django ──
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
# Your domain (and server IP if needed). Comma-separated, no spaces.
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Must include scheme. Used for CORS + CSRF when behind HTTPS.
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# ── Lasoo ──
# Base64 of 32 random bytes. Generate with:
#   python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
LASOO_ENCRYPTION_KEY=change-me
LASOO_TIMEOUT=30
LASOO_DEFAULT_STAGING_BASE_URL=https://stage.api.lasoo.com.au
LASOO_DEFAULT_PRODUCTION_BASE_URL=

# ── Hosting ──
# Port the frontend (nginx) listens on. Use 80 for plain HTTP.
HTTP_PORT=80
