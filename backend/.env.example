# ── App-level secrets (one per deployment, NOT per store) ──
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/leeso

# App-wide key used to encrypt every store's Lasoo AuthKeys.
# Generate with: python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"
LASOO_ENCRYPTION_KEY=

# CORS (React dev server)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Optional defaults for NEW connections only ──
# Per-store base URLs and endpoint paths are entered in the UI and stored in the DB.
# These are just prefilled values when a user opens the Connect form.
LASOO_DEFAULT_STAGING_BASE_URL=https://stage.api.lasoo.com.au
LASOO_DEFAULT_PRODUCTION_BASE_URL=https://api.lasoo.com.au
LASOO_DEFAULT_ENDPOINT_TEST=/Core/TestNoAuthentication/1.0.0
LASOO_DEFAULT_ENDPOINT_BULK_UPSERT=/Variants/BulkUpsert/1.0.0
LASOO_DEFAULT_ENDPOINT_BULK_DELETE=/Variants/BulkDelete/1.0.0
LASOO_DEFAULT_ENDPOINT_VARIANTS_SEARCH=/Variants/Search/1.0.0
LASOO_DEFAULT_ENDPOINT_ORDERS=/Invoices/Search/1.0.0
LASOO_DEFAULT_ENDPOINT_CREATE_TEST_ORDER=/Orders/CreateTestOrder/1.0.0
LASOO_DEFAULT_ENDPOINT_SHIPPING=/Shipments/Upsert/1.0.0
LASOO_DEFAULT_ENDPOINT_SHIPMENTS_SEARCH=/Shipments/Search/1.0.0
